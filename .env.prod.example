# Production env for docker-compose.prod.yml
# Copy to .env.prod and fill in real values. NEVER commit .env.prod.

# ---------- OmniVoice ----------
OMNIVOICE_DEVICE=cuda
OMNIVOICE_DTYPE=float16
OMNIVOICE_MAX_TEXT_CHARS=2000
OMNIVOICE_DEFAULT_NUM_STEP=32
OMNIVOICE_WARMUP_ON_STARTUP=true
# OMNIVOICE_HF_ENDPOINT=https://hf-mirror.com   # optional mirror

# ---------- Cloudflare R2 ----------
OMNIVOICE_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
OMNIVOICE_S3_ACCESS_KEY_ID=<r2-access-key>
OMNIVOICE_S3_SECRET_ACCESS_KEY=<r2-secret>
OMNIVOICE_S3_REGION=auto
OMNIVOICE_S3_BUCKET=omnivoice
OMNIVOICE_S3_FORCE_PATH_STYLE=false
OMNIVOICE_S3_PRESIGN_EXPIRES=3600
# OMNIVOICE_S3_PUBLIC_ENDPOINT_URL=https://cdn.example.com  # optional CDN/proxy host for presigned URLs
OMNIVOICE_S3_REF_PREFIX=ref/
OMNIVOICE_S3_OUT_PREFIX=out/
OMNIVOICE_S3_ENSURE_BUCKET=false
