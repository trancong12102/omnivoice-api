# Override any setting via OMNIVOICE_* env vars
# OMNIVOICE_DEVICE=auto          # auto | cuda | mps | cpu
# OMNIVOICE_DTYPE=auto           # auto | float16 | bfloat16 | float32
# OMNIVOICE_MODEL_ID=k2-fsa/OmniVoice
# OMNIVOICE_WARMUP_ON_STARTUP=true
# OMNIVOICE_HF_ENDPOINT=https://hf-mirror.com

# ---------- Auth ----------
# Leave unset to disable auth. When set, clients must send header `X-API-Key: <value>`.
# OMNIVOICE_API_KEY=change-me

# ---------- S3 / R2 ----------
# Local MinIO defaults (match docker-compose.yml)
OMNIVOICE_S3_ENDPOINT_URL=http://localhost:9000
OMNIVOICE_S3_ACCESS_KEY_ID=minioadmin
OMNIVOICE_S3_SECRET_ACCESS_KEY=minioadmin
OMNIVOICE_S3_REGION=us-east-1
OMNIVOICE_S3_BUCKET=omnivoice
OMNIVOICE_S3_FORCE_PATH_STYLE=true
OMNIVOICE_S3_PRESIGN_EXPIRES=3600
# OMNIVOICE_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000   # host baked into presigned URLs; default = endpoint_url

# ---------- Prod: Cloudflare R2 ----------
# OMNIVOICE_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# OMNIVOICE_S3_ACCESS_KEY_ID=<r2-access-key>
# OMNIVOICE_S3_SECRET_ACCESS_KEY=<r2-secret>
# OMNIVOICE_S3_REGION=auto
# OMNIVOICE_S3_BUCKET=omnivoice
# OMNIVOICE_S3_FORCE_PATH_STYLE=false
# OMNIVOICE_S3_PUBLIC_ENDPOINT_URL=https://<public-r2-domain>
